---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import PortfolioSection from "@components/Portfolio/Portfolio.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/banner.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Portfolio" description="Meta description for the page" heroImage={optimizedImage}>
	<Banner title="Portfolio" image={optimizedImage} />
	<PortfolioSection />
	<CTA />
</BaseLayout>