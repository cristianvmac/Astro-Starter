---
// Utils
import { Picture, getImage } from "astro:assets";
import "../styles/service-1.css";
// Components
import BaseLayout from "../../layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/banner.jpg"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import port1 from "@assets/images/projects/port1.jpg";
import port2 from "@assets/images/projects/port2.jpg";
import port3 from "@assets/images/projects/port3.jpg";
import port4 from "@assets/images/projects/port4.jpg";
import port5 from "@assets/images/projects/port5.jpg";
import port6 from "@assets/images/projects/port6.jpg";
import port7 from "@assets/images/projects/port7.jpg";
import port8 from "@assets/images/projects/port8.jpg";
import port9 from "@assets/images/projects/port9.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Projects" description="Meta description for the page" heroImage={optimizedImage}>
	<!-- ============================================ -->
	<!--                    BANNER                   -->
	<!-- ============================================ -->

	<Banner title="Project 1" image={optimizedImage} />

	<!-- ============================================ -->
<!--                Side By Side                  -->
<!-- ============================================ -->

<section id="sbs"> 
    <div class="cs-container"> 
        <!-- Left Content Section--> 
        <div class="cs-content"> 
            <span class="cs-topper">Featured Service</span> 
            <h2 class="cs-title">Dolor scelerisque proin in vulputate</h2> 
            <p class="cs-text"> 
                 Lorem ipsum dolor sit amet, bibendum dolor maecenas ipsum, in turpis sem. Nullam pede est vestibulum adipiscing suspendisse purus. Massa fusce phasellus et. Eros elit aliquam amet, placerat donec, dui dolor nec suscipit quis. Proin mattis ut nulla a mauris vivamus, varius aliquet vel quam, habitasse sed, curabitur arcu sed sollicitudin. Pede orci, nibh ut congue lorem platea, cras feugiat et ornare primis praesent euismod, ac ipsum. 
            </p> 
            <div class="cs-features"> 
                <h3 class="cs-h3">Key Features:</h3> 
                <ul class="cs-ul"> 
                    <li class="cs-li">Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis</li> 
                    <li class="cs-li">Nemo enim ipsam voluptatem, quia voluptas sit</li> 
                    <li class="cs-li">Ut enim ad minima veniam</li> 
                </ul> 
            </div> 
            <a class="cs-button-solid" aria-label="learn more about our programs" href="">Read More</a> 
        </div> 
        <!-- Right Image Section --> 
        <div class="cs-image-group"> 
            
            <!--Image--> 
            <picture class="cs-picture"> 
    			<source media="(max-width: 600px)" srcset="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600&q=80"> 
    			<source media="(min-width: 601px)" srcset="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&q=80"> 
    			<img loading="lazy" decoding="async" src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&q=80" alt="modern glass office building architecture" width="630" height="630" aria-hidden="true"> 
			</picture>
        </div> 
    </div> 
</section>
	<CTA />
</BaseLayout>


