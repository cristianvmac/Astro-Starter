---
// Utils
import { Picture, getImage } from "astro:assets";
import "../styles/project-1.css";
// Components
import BaseLayout from "../../layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/banner.jpg"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import port1 from "@assets/images/projects/port1.jpg";
import port2 from "@assets/images/projects/port2.jpg";
import port3 from "@assets/images/projects/port3.jpg";
import port4 from "@assets/images/projects/port4.jpg";
import port5 from "@assets/images/projects/port5.jpg";
import port6 from "@assets/images/projects/port6.jpg";
import port7 from "@assets/images/projects/port7.jpg";
import port8 from "@assets/images/projects/port8.jpg";
import port9 from "@assets/images/projects/port9.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Projects" description="Meta description for the page" heroImage={optimizedImage}>
	<!-- ============================================ -->
	<!--                    BANNER                   -->
	<!-- ============================================ -->

	<Banner title="Project 1" image={optimizedImage} />

	<!-- ============================================ -->
	<!--                   Gallery                    -->
	<!-- ============================================ -->

	<section id="gallery">
		<div class="cs-container">
			<div class="cs-image-group">
				<!-- Row 1-->
				<div class="cs-row cs-row-1">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<Picture src={port1} alt="new hallway" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} />
					<Picture src={port4} alt="new home construction" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} />
					<Picture src={port7} alt="building a new wall" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} />
				</div>
				<!-- Row 2 -->
				<div class="cs-row cs-row-2">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<Picture src={port2} alt="new kitchen" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} />
					<Picture src={port5} alt="apartment addition" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} />
					<Picture src={port8} alt="new kitchen cabinets" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} />
				</div>
				<!-- Row 3 -->
				<div class="cs-row cs-row-3">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<Picture src={port3} alt="new kitchen" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} />
					<Picture src={port6} alt="apartment addition" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} />
					<Picture src={port9} alt="new kitchen cabinets" width={400} height={560} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} />
				</div>
			</div>
			<a href="/contact/" class="cs-button-solid">Get Free Quote</a>
		</div>
	</section>
	<CTA />
</BaseLayout>


