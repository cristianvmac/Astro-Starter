---
import { getImage } from "astro:assets";
import "@styles/picture.css";

// TS types
interface Props {
	mobileImgUrl: string | ImageMetadata;
	mobileMediaWidth?: string;
	desktopImgUrl: string | ImageMetadata;
	desktopMediaWidth?: string;
	fallbackImgUrl: string | ImageMetadata;
	alt: string;
}

const { mobileImgUrl, mobileMediaWidth = "600px", desktopImgUrl, desktopMediaWidth = "601px", fallbackImgUrl, alt } = Astro.props;

const mobileImg = await getImage({
	src: mobileImgUrl,
	format: "webp",
	width: 640,
});

const desktopImg = await getImage({
	src: desktopImgUrl,
	format: "webp",
	width: 1240,
});

const fallbackImg = await getImage({
	src: fallbackImgUrl,
	format: "jpg",
	width: 1240,
});
---

<!-- Adjust the width and height attributes sizes based on the stitch you're using -->
<picture>
	<source media=`(max-width: ${mobileMediaWidth})` srcset={mobileImg.src} />
	<source media=`(min-width: ${desktopMediaWidth})` srcset={desktopImg.src} />
	<img aria-hidden="true" decoding="async" src={fallbackImg.src} alt={alt} loading="lazy" />
</picture>

