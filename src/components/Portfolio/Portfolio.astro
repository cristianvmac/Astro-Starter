---
//  this way to load images is easier than in Gallery component

import { Image } from 'astro:assets';
import "@styles/portfolio.css";

// Import your images - adjust paths based on your actual project structure
import port1 from '@assets/images/portfolio/port1.jpg';
import port2 from '@assets/images/portfolio/port2.jpg';
import port3 from '@assets/images/portfolio/port3.jpg';
import port4 from '@assets/images/portfolio/port4.jpg';
import port5 from '@assets/images/portfolio/port5.jpg';
import port6 from '@assets/images/portfolio/port6.jpg';
import port7 from '@assets/images/portfolio/port7.jpg';
import port8 from '@assets/images/portfolio/port8.jpg';
import port9 from '@assets/images/portfolio/port9.jpg';
---

<section id="gallery">
  <div class="cs-container">
    <span class="cs-topper">Our Portfolio</span>
    <h2 class="cs-title">Et orci volutpat, back up generator installations</h2>
    
    <div class="cs-image-group">
      <!-- Row 1 -->
      <div class="cs-row cs-row-1">
        <Image src={port1} alt="port1" class="cs-picture cs-picture-1" loading="lazy" width={400} />
        <Image src={port4} alt="port2" class="cs-picture cs-picture-2" loading="lazy" width={400} />
        <Image src={port7} alt="port3" class="cs-picture cs-picture-3" loading="lazy" width={400} />
      </div>

      <!-- Row 2 -->
      <div class="cs-row cs-row-2">
        <Image src={port2} alt="port4" class="cs-picture cs-picture-1" loading="lazy" width={400} />
        <Image src={port5} alt="port5" class="cs-picture cs-picture-2" loading="lazy" width={400} />
        <Image src={port8} alt="port6" class="cs-picture cs-picture-3" loading="lazy" width={400} />
      </div>

      <!-- Row 3 -->
      <div class="cs-row cs-row-3">
        <Image src={port3} alt="port7" class="cs-picture cs-picture-1" loading="lazy" width={400} />
        <Image src={port6} alt="port8" class="cs-picture cs-picture-2" loading="lazy" width={400} />
        <Image src={port9} alt="port9" class="cs-picture cs-picture-3" loading="lazy" width={400} />
      </div>
    </div>

    <a href="/gallery" class="button-solid">View Full Gallery</a>
  </div>
</section>